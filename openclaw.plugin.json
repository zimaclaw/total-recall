{
  "id": "total-recall",
  "kind": "extension",
  "hooks": [
    "command:new",
    "message:received",
    "before:prompt:build",
    "message:sent",
    "after:tool:call"
  ],
  "uiHints": {
    "enabled": {
      "label": "Enabled",
      "help": "Enable auto flashback before agent starts"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "debug": {
        "type": "boolean",
        "default": false,
        "description": "Enable debug logging"
      },
      "paths": {
        "type": "object",
        "properties": {
          "log": {
            "type": "string",
            "default": "/tmp/total-recall.log"
          },
          "memoryReflect": {
            "type": "string",
            "default": "/home/ironman/.openclaw/skills/memory-reflect"
          },
          "coreMd": {
            "type": "string",
            "default": "/home/ironman/.openclaw/workspace/CORE.md"
          }
        }
      },
      "kb": {
        "type": "object",
        "properties": {
          "scoreThreshold": {
            "type": "number",
            "default": 0.55
          },
          "maxResults": {
            "type": "integer",
            "default": 3
          }
        }
      },
      "curator": {
        "type": "object",
        "properties": {
          "defaultContext": {
            "type": "integer",
            "default": 32000
          }
        }
      },
      "embeddings": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "default": "http://192.168.1.145:11435"
          },
          "model": {
            "type": "string",
            "default": "bge-m3"
          },
          "timeout": {
            "type": "integer",
            "default": 30000
          }
        }
      },
      "llm": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "default": "ollama"
          },
          "url": {
            "type": "string",
            "default": "http://192.168.1.145:11434"
          },
          "model": {
            "type": "string",
            "default": "qwen3.5:27b-q4_K_M-N2"
          },
          "timeout": {
            "type": "integer",
            "default": 60000
          }
        }
      },
      "postgresql": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "default": "192.168.1.145"
          },
          "port": {
            "type": "integer",
            "default": 5432
          },
          "database": {
            "type": "string",
            "default": "openclaw"
          }
        }
      },
      "handoff": {
        "type": "object",
        "properties": {
          "maxMessages": {
            "type": "integer",
            "default": 20
          },
          "similarityThreshold": {
            "type": "number",
            "default": 0.3
          },
          "minMessagesForSemantic": {
            "type": "integer",
            "default": 15
          },
          "alwaysIncludeLast": {
            "type": "integer",
            "default": 5
          }
        }
      }
    },
    "required": []
  }
}
