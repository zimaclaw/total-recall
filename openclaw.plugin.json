{
  "id": "total-recall",
  "kind": "extension",
  "hooks": [
    "command:new",
    "message:received",
    "before:prompt:build",
    "message:sent",
    "after:tool:call"
  ],
  "uiHints": {
    "enabled": {
      "label": "Enabled",
      "help": "Enable auto flashback before agent starts"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      }
    },
    "required": []
  }
}
