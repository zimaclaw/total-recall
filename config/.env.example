# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://${IP_ADDRESS:-localhost}:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=${NEO4J_PASSWORD}

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=${IP_ADDRESS:-localhost}
QDRANT_PORT=6333
QDRANT_COLLECTION=reflections
SIMILARITY_THRESHOLD=0.40

# ─── Embeddings & Reranker (ollama) ───────────────────────────────────────────
EMBED_URL=http://${IP_ADDRESS:-localhost}:11435/api/embeddings
EMBED_MODEL=bge-m3:latest
RERANK_URL=http://${IP_ADDRESS:-localhost}:11437/api/embeddings
RERANK_MODEL=xitao/bge-reranker-v2-m3:latest

# ─── LLM для рефлексии (ollama основной) ─────────────────────────────────────
OLLAMA_URL=http://${IP_ADDRESS:-localhost}:11434/api/chat
REFLECT_MODEL=qwen3:14b

# ─── Пути ─────────────────────────────────────────────────────────────────────
DUMP_DIR=/home/ironman/.openclaw/workspace/memory/dumps
LOG_DIR=/home/ironman/.openclaw/workspace/logs

# ─── Триггеры рефлексии демона ────────────────────────────────────────────────
REFLECT_TRIGGER_COUNT=10
REFLECT_TRIGGER_HOURS=24
REFLECT_POLL_SECONDS=300

# ─── Пороги ───────────────────────────────────────────────────────────────────
FLASHBACK_THRESHOLD=0.60
LESSON_CONF_THRESHOLD=0.75
LESSON_MASTERY_THRESHOLD=0.60
NEEDS_REVIEW_THRESHOLD=0.40
PRINCIPLE_MIN_CLUSTER=3
PRINCIPLE_CONF_THRESHOLD=0.70
META_MIN_CLUSTER=2
