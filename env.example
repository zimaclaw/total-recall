# total-recall env.example
# cp env.example .env и заполни под свою машину

# ─── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://192.168.1.145:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=192.168.1.145
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
SIMILARITY_THRESHOLD=0.72

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PG_DSN=postgresql://openclaw:your_password@192.168.1.145:5432/openclaw

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBED_URL=http://192.168.1.145:11435/api/embed
EMBED_MODEL=bge-m3:latest
# RERANK_URL и RERANK_MODEL — deprecated, не используются

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://192.168.1.145:11434
OLLAMA_URL=http://192.168.1.145:11434/api/chat
REFLECT_MODEL=qwen3.5:27b-q4_K_M

# ─── Пути ────────────────────────────────────────────────────────────────────
MEMORY_REFLECT_DIR=/home/YOUR_USER/.openclaw/skills/memory-reflect
DUMP_DIR=/home/YOUR_USER/.openclaw/workspace/memory/dumps
LOG_DIR=/home/YOUR_USER/.openclaw/workspace/logs

# ─── OpenClaw ────────────────────────────────────────────────────────────────
OPENCLAW_CONFIG_PATH=/home/YOUR_USER/.openclaw/openclaw.json
CURATOR_DEFAULT_CONTEXT=32000

# ─── Flashback ───────────────────────────────────────────────────────────────
FLASHBACK_CONCLUSION_LIMIT=5
FLASHBACK_CONCLUSION_THRESHOLD=0.65
FLASHBACK_PRINCIPLE_THRESHOLD=0.70
FLASHBACK_META_THRESHOLD=0.80

# ─── Фокус ───────────────────────────────────────────────────────────────────
FOCUS_TOP_K=5
FOCUS_MIN_SIMILARITY=0.40
FOCUS_MAX_TOKENS=3000
FOCUS_PAIR_MAX_TOKENS=500

# ─── Skeleton ────────────────────────────────────────────────────────────────
SKELETON_TAIL_PAIRS=10
SKELETON_SUMMARY_ENABLED=false
SKELETON_SUMMARY_MAX_TOKENS=1000
SKELETON_SUMMARY_CACHE=true

# ─── KB ──────────────────────────────────────────────────────────────────────
KB_TOP_K=10
KB_SUMMARY_MAX_TOKENS=300
KB_MAX_TOKENS=3000

# ─── Debug ───────────────────────────────────────────────────────────────────
# TOTAL_RECALL_DEBUG=1

# ─── Пути (дополнение) ───────────────────────────────────────────────────────
CORE_MD_PATH=/home/YOUR_USER/.openclaw/workspace/CORE.md
